# Runtime config (filled in per-operator; contains identifiers — never commit).
config.env

# Built deploy artifact — regenerated by build-function.sh from v2-v3-redirect.js.
dist/

# Node deps for the Jest unit-test suite.
node_modules/

# Raw working dumps from clone-distribution.sh / verify-clone.sh, notably
# prod-config.json (a full `aws cloudfront get-distribution-config` of the
# production distribution). MUST NOT be committed to this public repo: a raw
# distribution config can carry origin custom-header values (a common place for
# origin-auth shared secrets) and other non-identifier data (SEC-J1; SEC-F3
# accepted infrastructure *identifiers*, not raw dumps). The one R26c artifact
# meant to be committed — the DNS-audit record — is written outside artifacts/
# (see dns-audit-record.md at the folder root). Any config dump checked in, or
# pasted into a spec, must first be inspected for origin custom-header values.
artifacts/
