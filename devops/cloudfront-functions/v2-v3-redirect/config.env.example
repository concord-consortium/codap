# devops/cloudfront-functions/v2-v3-redirect/config.env.example
# Copy to config.env (git-ignored) and fill in. Identifiers from
# specs/CODAP-1323-redirect-v2-to-v3.md "Technical Notes" section.
PROD_DIST_ID=E3H9X49AG3GYSO                       # current codap.concord.org distribution
PROD_DIST_DOMAIN=d13zmjbnp90bac.cloudfront.net    # its CloudFront domain
HOSTED_ZONE_ID=Z2P4W3M7MDAUV6                     # concord.org Route 53 zone
ACM_CERT_ARN=arn:aws:acm:us-east-1:612297603577:certificate/2b62511e-ccc8-434b-ba6c-a8c33bbd509e
TEMP_SUBDOMAIN=codap2to3.concord.org              # pre-flip validation host (R27)
FUNCTION_NAME=codap-v2-v3-redirect                # CloudFront Function name
CLONE_DIST_ID=                                    # filled in by clone-distribution.sh
CLONE_DIST_DOMAIN=                                # filled in by clone-distribution.sh
RHP_REQUIRED=                                     # filled in by clone-distribution.sh step 4 (DO-I1): true|false
RHP_ID=                                           # filled in by clone-distribution.sh step 4 (if a response-headers policy already exists)

# --- Synthetics canaries (deploy-monitoring.sh) ---------------------------------------
# Host the canaries probe. Pre-flip set to $TEMP_SUBDOMAIN (codap2to3.concord.org); post-flip
# set to codap.concord.org and delete+recreate the canaries (DO-F2; see RUNBOOK.md
# "Canary re-pointing"). Unset defaults to $TEMP_SUBDOMAIN.
CANARY_TARGET_HOST=codap.concord.org
# IAM role the canaries run as, and the S3 bucket for their code package + run artifacts.
# Required for deploy-monitoring.sh to create canaries; if either is empty the script skips
# canary creation. The bucket must be in us-east-1 (same region as the canaries).
SYNTHETICS_ROLE_ARN=arn:aws:iam::612297603577:role/codap-cw-synthetics-execution-role
SYNTHETICS_ARTIFACT_BUCKET=codap-cw-synthetics-artifacts

# --- V2 cached-launch recovery (TEMPORARY; CODAP-1323 follow-on) -----------------------
# Spec: specs/CODAP-1323-v2-cached-launch-recovery.md. When true, modify-clone.sh adds
# three head-of-array carve-outs (/app/static/*, /app/codap-config.js, /app/extn/*) that
# route the V2 asset paths under /app to the V2 origin via the recovery function below, so
# stale cached V2 shells can finish booting after the cutover. Default false -- nothing
# happens until an operator opts in. Set back to false and re-run modify-clone.sh to remove
# the carve-outs at teardown (~2-3 weeks post-cutover).
RECOVERY_APP_V2_ASSETS=false
# CloudFront Function (devops/cloudfront-functions/v2-asset-recovery/) that strips /app and
# pins the May-22 build. Must be published to LIVE (its deploy-function.sh) before
# modify-clone.sh attaches it by ARN.
RECOVERY_FUNCTION_NAME=codap-app-v2-recovery
